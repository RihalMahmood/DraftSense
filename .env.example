#Environment Variables

PORT=5000
NODE_ENV=development

#MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@draftsense.ztsaxdi.mongodb.net/?appName=DraftSense

#Client URL (for CORS)
CLIENT_URL=http://localhost:5173

#AI Provider Toggle
#Use "ollama" for local dev | "anthropic" for production
AI_PROVIDER=ollama

#Ollama (local dev)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Anthropic Claude (production only)
#ANTHROPIC_API_KEY=
