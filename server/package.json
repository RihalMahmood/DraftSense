{
  "name": "draftsense-server",
  "version": "1.0.0",
  "description": "DraftSense backend — League of Legends champion select advisor API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "ts-node src/scripts/seedDatabase.ts",
    "seed:matchups": "ts-node src/scripts/seedMatchups.ts",
    "seed:synergies": "ts-node src/scripts/seedSynergies.ts",
    "seed:builds": "ts-node src/scripts/seedBuilds.ts",
    "seed:builds:real": "ts-node src/scripts/seedBuildsReal.ts",
    "seed:real": "ts-node src/scripts/seedRealData.ts",
    "seed:all": "npm run seed && npm run seed:matchups && npm run seed:synergies && npm run seed:builds:real",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "mongoose": "^8.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "eslint": "^8.57.0",
    "nodemon": "^3.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}